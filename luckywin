<!-- START: Yakshagana Scratch & Win (luckywin-c8365) -->
<section id="yaksha-scratch-win" style="padding:20px; background:#fff; margin:20px 0; border-radius:12px; box-shadow:0 4px 8px rgba(0,0,0,0.06);">
  <h2 style="margin-bottom:8px;">ಯಕ್ಷಗಾನ Scratch & Win</h2>
  <p style="margin-top:0;color:#555;">WhatsApp ಸಂಖ್ಯೆಯನ್ನು ಹಾಕಿ ಒಂದು ಕಾರ್ಡ್ ಸ್ಕ್ರ್ಯಾಚ್ ಮಾಡಿ — ಪ್ರತೊಬ್ಬರು ಒಂದು ಬಾರಿ ಮಾತ್ರ. (Admin ಮೂಲಕ ಮರುಹೊಂದಿಸಲಾಗುತ್ತದೆ)</p>

  <div id="scratch-login" style="max-width:420px;margin:12px auto;text-align:center;">
    <input id="scratch-whatsapp" type="text" placeholder="WhatsApp Number (e.g. 9148014768)" style="width:78%; padding:10px;border-radius:8px;border:1px solid #ccc;">
    <button id="scratch-login-btn" style="padding:10px 16px;border-radius:8px;background:#ff6f61;color:#fff;border:none;margin-left:8px;cursor:pointer;">Login</button>
  </div>

  <div id="scratch-area" style="display:none; max-width:820px;margin:8px auto;">
    <div id="cardsContainer" style="display:flex;flex-wrap:wrap;justify-content:center;"></div>
    <div style="margin-top:12px; text-align:center;">
      <button id="scratch-submit" style="padding:10px 20px;border-radius:8px;background:#2b8aef;color:#fff;border:none;cursor:pointer;">Send Prize to WhatsApp</button>
    </div>

    <h4 style="margin-top:18px;">Winners</h4>
    <div id="winnerList" style="min-height:40px;color:#333;"></div>
    <div style="text-align:center;margin-top:12px;">
      <button id="scratch-admin-open" style="padding:8px 14px;border-radius:8px;background:#444;color:#fff;border:none;cursor:pointer;">Admin Panel</button>
    </div>
  </div>

  <!-- Admin panel (hidden, password protected) -->
  <div id="scratch-admin" style="display:none; max-width:640px;margin:16px auto;padding:12px;border-radius:10px;border:1px solid #e6e6e6;background:#fafafa;">
    <h4>Scratch Admin</h4>
    <input id="scratch-admin-pass" type="password" placeholder="Admin password" style="padding:8px;border-radius:6px;border:1px solid #ccc;">
    <button id="scratch-admin-login" style="padding:8px 12px;margin-left:8px;border-radius:6px;background:#2b8aef;color:#fff;border:none;cursor:pointer;">Login</button>

    <div id="scratch-admin-controls" style="display:none;margin-top:12px;">
      <h5>Edit Prizes</h5>
      <div id="scratch-prizes-editor"></div>
      <div style="margin-top:8px;">
        <button id="scratch-update-prizes" style="padding:8px 12px;border-radius:6px;background:#ff6f61;color:white;border:none;cursor:pointer;">Update Prizes</button>
        <button id="scratch-admin-logout" style="padding:8px 12px;border-radius:6px;background:#777;color:white;border:none;cursor:pointer;margin-left:8px;">Logout</button>
      </div>

      <h5 style="margin-top:12px;">Manage Users</h5>
      <div id="scratch-users-list"></div>
    </div>
  </div>
</section>

<!-- Firebase + Scratch script (uses luckywin-c8365 Realtime DB) -->
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
<script>
(function(){
  // ====== Firebase config for luckywin-c8365 ======
  const firebaseConfig = {
    apiKey: "AIzaSyCcGujjBbE9j8G4-9yNnZcIncUDwCMNvDI",
    authDomain: "luckywin-c8365.firebaseapp.com",
    databaseURL: "https://luckywin-c8365-default-rtdb.firebaseio.com/",
    projectId: "luckywin-c8365",
    storageBucket: "luckywin-c8365.appspot.com",
    messagingSenderId: "542970385202",
    appId: "1:542970385202:web:ca949d82b00aca9c2a7d2b",
    measurementId: "G-4FSDQHFR8N"
  };
  firebase.initializeApp(firebaseConfig);
  const database = firebase.database();

  // ====== Config / state ======
  const totalCards = 20;
  let prizes = Array.from({length: totalCards}, (_,i) => `Prize ${i+1}`);
  let users = {};      // saved as /users/{whatsapp} => {prize, cardIndex}
  let winners = [];    // saved as /winners/{cardIndex} => {index,prize,number}
  let currentUser = null;

  // ====== DOM refs ======
  const loginBtn = document.getElementById('scratch-login-btn');
  const loginInput = document.getElementById('scratch-whatsapp');
  const scratchArea = document.getElementById('scratch-area');
  const cardsContainer = document.getElementById('cardsContainer');
  const winnerList = document.getElementById('winnerList');
  const submitBtn = document.getElementById('scratch-submit');
  const adminOpenBtn = document.getElementById('scratch-admin-open');
  const adminPanel = document.getElementById('scratch-admin');
  const adminLoginBtn = document.getElementById('scratch-admin-login');
  const adminPassInput = document.getElementById('scratch-admin-pass');
  const adminControls = document.getElementById('scratch-admin-controls');
  const prizesEditor = document.getElementById('scratch-prizes-editor');
  const updatePrizesBtn = document.getElementById('scratch-update-prizes');
  const adminLogoutBtn = document.getElementById('scratch-admin-logout');
  const usersList = document.getElementById('scratch-users-list');

  // ====== Load data from Firebase ======
  function loadAll(){
    database.ref('prizes').once('value', snap => {
      if(snap.exists()) prizes = snap.val();
      renderCards();
    });
    database.ref('winners').once('value', snap => {
      if(snap.exists()) winners = Object.values(snap.val());
      renderCards();
      renderWinners();
    });
    database.ref('users').once('value', snap => {
      if(snap.exists()) users = snap.val();
    });
    // Add realtime listeners so changes appear instantly
    database.ref('winners').on('value', snap => {
      winners = snap.exists() ? Object.values(snap.val()) : [];
      renderCards();
      renderWinners();
    });
    database.ref('prizes').on('value', snap => {
      prizes = snap.exists() ? snap.val() : prizes;
      renderCards();
    });
    database.ref('users').on('value', snap => {
      users = snap.exists() ? snap.val() : {};
      renderUsersAdmin();
    });
  }

  // ====== UI render ======
  function renderCards(){
    cardsContainer.innerHTML = '';
    for(let i=0;i<totalCards;i++){
      const winner = winners.find(w => w.index === i);
      const prizeText = winner ? winner.prize : prizes[i] || '';
      const card = document.createElement('div');
      card.className = 'scratch-card';
      card.style.cssText = 'width:110px;height:110px;margin:8px;border-radius:12px;background:#f2f2f2;position:relative;display:flex;align-items:center;justify-content:center;font-weight:bold;cursor:pointer;box-shadow:0 4px 6px rgba(0,0,0,0.08);';
      card.id = 'scratch-card-'+i;
      const layer = document.createElement('div');
      layer.className = 'scratch-layer';
      layer.style.cssText = 'position:absolute;inset:0;background:#bdbdbd;border-radius:12px;transition:opacity .25s;';
      const text = document.createElement('span');
      text.className = 'prize-text';
      text.textContent = prizeText;
      text.style.zIndex = 1;
      card.appendChild(layer);
      card.appendChild(text);

      // visually show scratched
      if(winner) layer.style.opacity = '0';

      (function(idx){
        card.addEventListener('click', () => tryScratch(idx));
      })(i);

      cardsContainer.appendChild(card);
    }
  }

  function renderWinners(){
    winnerList.innerHTML = winners.map(w => `ಜಯ: ${w.prize}`).join('<br>') || 'ಇಲ್ಲಿ ಯಾವುದೇ ಘಟನೆಗಳಿಲ್ಲ';
  }

  // ====== Scratch logic ======
  function tryScratch(index){
    if(!currentUser){ alert('ದಯವಿಟ್ಟು ಮೊದಲು WhatsApp ಸಂಖ್ಯೆ ನಮೂದಿಸಿ ಮತ್ತು Login ಒತ್ತಿ.'); return; }
    // check user already scratched
    if(users[currentUser]) { alert('ನೀವು ಈಗಾಗಲೇ ಕಾರ್ಡ್ ಸ್ಕ್ರ್ಯಾಚ್ ಮಾಡಿದ್ದಾರೆ. Admin ಮೂಲಕ ಮರುಹೊಂದಿಸಬಹುದಾಗಿದೆ.'); return; }
    // check card already scratched
    const existing = winners.find(w => w.index === index);
    if(existing){ alert('ಈ ಕಾರ್ಡ್ ಈಗಾಗಲೇ ಸ್ಕ್ರ್ಯಾಚ್ ಆಗಿದೆ'); return; }

    // perform scratch
    const prize = prizes[index] || `Prize ${index+1}`;
    const winnerData = { index: index, prize: prize, number: currentUser };
    // write user and winner atomically
    database.ref('users/' + currentUser).set({ prize: prize, cardIndex: index })
      .then(() => database.ref('winners/' + index).set(winnerData))
      .then(() => {
        // UI updates are driven by realtime listeners, but update local state too
        users[currentUser] = { prize: prize, cardIndex: index };
        winners.push(winnerData);
        renderCards();
        renderWinners();
        alert('Congratulations! Prize revealed and saved.');
      })
      .catch(err => { console.error(err); alert('Error saving to database. Check console.'); });
  }

  // ====== Login / Submit handlers ======
  loginBtn.addEventListener('click', () => {
    const val = loginInput.value && loginInput.value.trim();
    if(!val) { alert('ದಯವಿಟ್ಟು WhatsApp ಸಂಖ್ಯೆ ನಮೂದಿಸಿ'); return; }
    if(users[val]) { alert('ಈ ಸಂಖ್ಯೆ ಈಗಾಗಲೇ ಬಳಸಿದೆ — adminರನ್ನು ಸಂಪರ್ಕಿಸಿ'); return; }
    currentUser = val;
    scratchArea.style.display = 'block';
    document.getElementById('scratch-login').style.display = 'none';
    renderCards();
  });

  submitBtn.addEventListener('click', () => {
    if(!currentUser){ alert('Login ಮಾಡಿ ಮೊದಲು.'); return; }
    const u = users[currentUser];
    if(!u){ alert('ನೀವು ಇನ್ನೂ ಸ್ಕ್ರ್ಯಾಚ್ ಮಾಡಿಲ್ಲ'); return; }
    const whatsappNumber = '9148014768';
    const message = encodeURIComponent(`ನನ್ನ ಜಯ: ${u.prize} (WhatsApp: ${currentUser})`);
    const a = document.createElement('a'); a.href = `https://wa.me/${whatsappNumber}?text=${message}`; a.target = '_blank';
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
  });

  // ====== Admin UI ======
  adminOpenBtn.addEventListener('click', () => { adminPanel.style.display = 'block'; adminPanScrollIntoView(); });
  function adminPanScrollIntoView(){ adminPanel.scrollIntoView({behavior:'smooth'}); }

  adminLoginBtn.addEventListener('click', () => {
    const pass = adminPassInput.value;
    if(pass !== 'admin123'){ alert('Incorrect admin password'); return; }
    adminControls.style.display = 'block';
    renderPrizeEditor();
    renderUsersAdmin();
  });

  adminLogoutBtn.addEventListener('click', () => {
    adminControls.style.display = 'none';
    adminPassInput.value = '';
  });

  function renderPrizeEditor(){
    prizesEditor.innerHTML = '';
    for(let i=0;i<totalCards;i++){
      const label = document.createElement('div'); label.style.marginTop='6px';
      const input = document.createElement('input');
      input.value = prizes[i] || '';
      input.id = 'scratch-prize-input-'+i;
      input.style.padding='8px'; input.style.width='72%'; input.style.borderRadius='6px'; input.style.border='1px solid #ccc';
      label.appendChild(document.createTextNode('Card ' + (i+1) + ': '));
      label.appendChild(input);
      prizesEditor.appendChild(label);
    }
  }

  updatePrizesBtn.addEventListener('click', () => {
    for(let i=0;i<totalCards;i++){
      const v = document.getElementById('scratch-prize-input-'+i).value;
      prizes[i] = v;
    }
    database.ref('prizes').set(prizes)
      .then(()=> { alert('Prizes updated.'); renderCards(); })
      .catch(err => { console.error(err); alert('Error updating prizes'); });
  });

  // ====== Admin users list and removal ======
  function renderUsersAdmin(){
    usersList.innerHTML = '';
    // build from current DB state in `users` object
    const keys = Object.keys(users || {});
    if(keys.length === 0){ usersList.innerHTML = 'No users yet'; return; }
    keys.forEach(k => {
      const u = users[k];
      const div = document.createElement('div');
      div.style.marginTop='8px';
      div.innerHTML = `Number: <strong>${k}</strong> — Prize: ${u.prize || '-'} `;

      const rem = document.createElement('button');
      rem.textContent = 'Remove';
      rem.style.marginLeft='8px';
      rem.style.padding='6px 10px';
      rem.style.borderRadius='6px';
      rem.style.border='none';
      rem.style.background='#ff6f61';
      rem.style.color='white';
      rem.style.cursor='pointer';
      rem.addEventListener('click', () => {
        if(!confirm('Remove this user and free their card?')) return;
        // remove user and related winner
        database.ref('users/' + k).remove()
          .then(() => {
            // Remove winner entry (if exists and belongs to this user)
            database.ref('winners').once('value', s => {
              if(!s.exists()) return;
              const vals = s.val();
              Object.keys(vals).forEach(cardIndex => {
                const w = vals[cardIndex];
                if(w.number === k) database.ref('winners/' + cardIndex).remove();
              });
            });
          })
          .then(() => { alert('Removed user.'); })
          .catch(e => { console.error(e); alert('Error removing user.'); });
      });
      div.appendChild(rem);
      usersList.appendChild(div);
    });
  }

  // ====== Start ======
  loadAll();

})();
</script>
<!-- END: Yakshagana Scratch & Win (luckywin-c8365) -->
